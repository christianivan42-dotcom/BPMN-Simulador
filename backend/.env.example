# ════════════════════════════════════════════════════════════════════════════════
# .env.example — BPMS Cognitive Platform v2.0 (Ola 4)
# Copia este archivo como  backend/.env  y rellena tus valores
# ════════════════════════════════════════════════════════════════════════════════

APP_NAME=Agente BPMS - Experto en Procesos
APP_VERSION=2.0.0
APP_ENV=local                   # local | staging | production
API_PREFIX=/api/v1
FRONTEND_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000"]

# ── Base de datos ────────────────────────────────────────────────────────────
# dev: USE_POSTGRES=false → SQLite en storage/app.db
# prod: USE_POSTGRES=true + rellena POSTGRES_URL
USE_POSTGRES=false
POSTGRES_URL=postgresql://bpms:bpms@localhost:5432/bpms
DATABASE_URL=sqlite:///./storage/app.db
DOCUMENT_STORAGE_DIR=storage/documents
AGENT_TRAINING_DIR=docs/agent-training
OBSIDIAN_VAULT_DIR=storage/obsidian-bpm-vault
VECTOR_STORE_DIR=storage/vector_store

# ── Redis / Event Bus + Celery (Ola 4) ──────────────────────────────────────
# DEV SIN REDIS (por defecto):
#   - Deja estas vars vacías o comentadas.
#   - EventBus → InProcessEventBus   (pub/sub en memoria, mismo proceso)
#   - Celery   → memory:// broker    (worker arranca sin Redis)
#   - Limitación: resultados de tareas no sobreviven reinicios del worker.
#
# DEV/PROD CON REDIS (recomendado para probar el flujo completo):
#   - Descomenta y ajusta las tres vars.
#   - docker run -p 6379:6379 redis:7-alpine
#
# REDIS_URL=redis://localhost:6379
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
REDIS_URL=
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Knowledge Graph (Neo4j) ──────────────────────────────────────────────────
ENABLE_NEO4J=false
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_bpms

# ── Vector Store (Qdrant) ────────────────────────────────────────────────────
ENABLE_QDRANT=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=bpms_knowledge
QDRANT_EMBEDDING_MODEL=all-MiniLM-L6-v2
QDRANT_EMBEDDING_DIM=384

# ── Gemini (Google AI Studio) ────────────────────────────────────────────────
GEMINI_API_KEY=tu_gemini_api_key_aqui
GEMINI_MODEL=gemini-2.5-pro-latest
GEMINI_FLASH_MODEL=gemini-2.5-flash-latest

# ── Deepseek API ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=tu_deepseek_api_key_aqui
DEEPSEEK_MODEL=deepseek-chat

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=tu_groq_api_key_aqui
GROQ_MODEL=meta-llama/llama-4-scout

# ── Ollama (LLM local) ───────────────────────────────────────────────────────
LOCAL_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_REASONING_MODEL=deepseek-r1:32b
OLLAMA_REASONING_MODEL_UPGRADE=deepseek-r1:32b
OLLAMA_CODER_MODEL=deepseek-coder-v2
OLLAMA_FAST_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_EMBEDDING_MODEL_UPGRADE=qwen3-embedding:4b

# ── Mock / demo ──────────────────────────────────────────────────────────────
USE_MOCK_LLM=true              # true en dev, false en prod

# ── RAG / Embeddings ─────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=160

# ── Chat ─────────────────────────────────────────────────────────────────────
CHAT_MAX_HISTORY=20
CHAT_MAX_RAG_FRAGMENTS=5

# ── Governance / Auth (Ola 3-D) ──────────────────────────────────────────────
GOVERNANCE_SECRET=change-me-in-production-ola4
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@bpms.local
DEFAULT_ADMIN_PASSWORD=admin1234

# ── Notifications ────────────────────────────────────────────────────────────
NOTIFICATIONS_EMAIL_FROM=no-reply@bpms.local
NOTIFICATIONS_SMTP_HOST=
NOTIFICATIONS_SMTP_PORT=587
NOTIFICATIONS_SMTP_USER=
NOTIFICATIONS_SMTP_PASSWORD=
NOTIFICATIONS_WEBHOOK_URL=

# ── OpenTelemetry (Ola 4) ────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=bpms-backend
